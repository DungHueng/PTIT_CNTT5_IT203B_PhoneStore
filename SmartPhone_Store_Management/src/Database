DROP DATABASE IF EXISTS smartphoneStoreManagement;
CREATE DATABASE smartphoneStoreManagement;
USE smartphoneStoreManagement;

CREATE TABLE users (
    userId INT PRIMARY KEY AUTO_INCREMENT,
    fullName VARCHAR(255),
    userName VARCHAR(255),
    password VARCHAR(255),
    email VARCHAR(50) UNIQUE,
    phone VARCHAR(20),
    address VARCHAR(50),
    role ENUM ('ADMIN', 'CUSTOMER') DEFAULT 'CUSTOMER'
);

